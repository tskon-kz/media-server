# Telegram
BOT_TOKEN=your_bot_token_here
ALLOWED_USER=your_telegram_id_here

# Watchtower — auto-generated by install.sh, used for bot-triggered updates
WATCHTOWER_TOKEN=your_token_here

# Custom ports (optional — defaults are shown, uncomment to override)
# JELLYFIN_PORT=8096
# QB_PORT=8080

# Media storage (optional)
# MEDIA_PATH=./media       # host path mounted as /media in containers (e.g. /mnt/disk2)

# Everything else (SERVER_IP, PROXY_URL, JELLYFIN_API_KEY, qBittorrent password)
# is stored in bot-data/media_server.db and managed by the bot / install.sh.
